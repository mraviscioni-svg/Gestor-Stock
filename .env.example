# --- Core ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth (HS256). Minimum 16 chars. Rotate for production.
JWT_SECRET="replace-with-a-long-random-secret"

# Public hints (safe for browser)
NEXT_PUBLIC_APP_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: texto extra en /login (sin secretos)
NEXT_PUBLIC_DEMO_LOGIN_HINT=""

# One-shot en Vercel: POST /api/internal/bootstrap con header x-bootstrap-secret
# Generá un valor largo aleatorio; borrálo de Vercel después de usarlo.
BOOTSTRAP_SECRET=""
