# --- Core ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth (HS256). Minimum 16 chars. Rotate for production.
JWT_SECRET="replace-with-a-long-random-secret"

# Public hints (safe for browser)
NEXT_PUBLIC_APP_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: shown on /login for demos (no secrets here)
NEXT_PUBLIC_DEMO_LOGIN_HINT="Usuario seed: ver README (email/contraseña definidos al correr seed)."

# --- Seed only (never commit real secrets) ---
# Required to run `npm run db:seed`
SEED_DEMO_PASSWORD="change-me-8-chars-min"
SEED_DEMO_OWNER_EMAIL="owner@demo.kiosco.local"
