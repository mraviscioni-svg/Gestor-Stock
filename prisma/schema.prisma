generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
  CASHIER
  VIEWER
}

enum TenantStatus {
  PENDING_ONBOARDING
  ACTIVE
  SUSPENDED
}

enum SubscriptionStatus {
  NONE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  DEBIT
  CREDIT
  TRANSFER
  MERCADO_PAGO
}

enum StockMovementReason {
  SALE
  MANUAL_ADJUST
  INITIAL
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
}

enum SaleStatus {
  OPEN
  CLOSED
  CANCELLED
}

model Tenant {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  email              String?
  phone              String?
  logoUrl            String?
  subdomain          String?            @unique
  status             TenantStatus       @default(ACTIVE)
  currentPlan        String             @default("free")
  subscriptionStatus SubscriptionStatus @default(NONE)
  maxUsers           Int?
  maxProducts        Int?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  users          User[]
  categories     Category[]
  products       Product[]
  sales          Sale[]
  stockMovements StockMovement[]
  userActivities UserActivity[]

  @@index([slug])
  @@index([status])
}

model User {
  id           String   @id @default(cuid())
  /** Usuario para iniciar sesión (único por comercio). */
  username     String?
  /** Contacto opcional; no se usa en el login. */
  email        String?
  passwordHash String
  name         String?
  role         Role     @default(CASHIER)
  active       Boolean  @default(true)
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stockMovements StockMovement[]
  sales          Sale[]
  activities     UserActivity[]

  @@unique([tenantId, username])
  @@index([tenantId])
  @@index([username])
}

model Category {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products  Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Product {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name           String
  barcode        String
  purchasePrice  Decimal  @default(0) @db.Decimal(12, 2)
  salePrice      Decimal  @default(0) @db.Decimal(12, 2)
  stock          Int      @default(0)
  minStock       Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  saleItems      SaleItem[]
  stockMovements StockMovement[]

  @@unique([tenantId, barcode])
  @@index([tenantId])
  @@index([tenantId, name])
}

model Sale {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  total         Decimal         @db.Decimal(12, 2)
  paymentMethod PaymentMethod?
  paymentStatus PaymentStatus   @default(PAID)
  saleStatus    SaleStatus      @default(CLOSED)
  createdAt     DateTime        @default(now())
  closedAt      DateTime?

  items SaleItem[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
  @@index([tenantId, saleStatus])
  @@index([tenantId, paymentStatus])
}

model UserActivity {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSeenAt  DateTime @default(now())
  currentPage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([tenantId, lastSeenAt])
}

model SaleItem {
  id         String  @id @default(cuid())
  saleId     String
  sale       Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity   Int
  unitPrice  Decimal @db.Decimal(12, 2)
  lineTotal  Decimal @db.Decimal(12, 2)

  @@index([saleId])
  @@index([productId])
}

model StockMovement {
  id         String              @id @default(cuid())
  tenantId   String
  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId  String
  product    Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity   Int
  reason     StockMovementReason
  note       String?
  userId     String?
  user       User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime            @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([productId])
}

model AuditLog {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  actorUserId   String?
  actorTenantId String?
  action        String
  entityType    String?
  entityId      String?
  metadata      Json?
  ip            String?

  @@index([createdAt])
  @@index([actorTenantId, createdAt])
  @@index([action, createdAt])
}
